# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-a-long-random-secret
MAIN_BACKEND_INTERNAL_SECRET=change-me-use-a-long-random-secret

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2025-01-01-preview
MODEL_CHAT_FAST=gpt-4o-mini
MODEL_CHAT_THINKING=gpt-4o
MODEL_EMBEDDING=text-embedding-3-large

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_TOKEN_VALUE=your-r2-token
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
# Comma-separated list or JSON array of allowed CORS origins for main_backend
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]

# ── Inter-service URLs (set per deploy environment) ───────────────────────────
# In docker-compose these are overridden per service via environment: block.
AI_SERVICE_URL=http://ai_service:8001
MAIN_BACKEND_URL=http://main_backend:8000
